@using Microsoft.AspNetCore.Identity
@{
    ViewData["Title"] = "Index";
}

<h1 class="display-6 text-center">Create Role</h1>
<div>
    <h5 class="text-primary text-center">@ViewBag.msg</h5>
</div>

<div class="row justify-content-center mt-3">
    <div class="col-md-4">
        <div class="card p-3 shadow-sm">
            <form asp-action="CreateRole" asp-controller="Role" method="post">
                <label class="col-form-label">Role Name</label>
                <input type="text" name="userRole" value="" class="form-control" placeholder="Enter your role" />
                <button type="submit" class="btn btn-primary btn-sm mt-3 w-100">Save</button>
            </form>
        </div>
    </div>
</div>

<hr />

<div class="row justify-content-center text-center">
    <div class="col-md-6">
        <div class="card shadow-sm p-3">
            <table class="table table-bordered table-striped">
                <thead class="table-active">
                    <tr>
                        <th>SL</th>
                        <th>Role Name</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        int sl = 1;
                        var roles = ViewBag.RoleList as List<IdentityRole>;
                    }

                    @if (roles != null && roles.Count > 0)
                    {
                        foreach (var role in roles)
                        {
                            <tr>
                                <td>@sl</td>
                                <td>@role.Name</td>
                            </tr>
                            sl++;
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="2" class="text-center text-danger">
                                No roles found!
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>