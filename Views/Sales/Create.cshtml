@{
    ViewData["Title"] = "Create";
}

@model ShopManagementSystem.Models.ViewModels.SalesCreateVM

<link href="https://code.jquery.com/ui/1.13.2/themes/base/jquery-ui.css" rel="stylesheet" />

<div class="card shadow">

    <!-- HEADER -->
    <div class="bg-primary text-white p-3 d-flex justify-content-between">
        <h4>SUPER SHOP</h4>
        <div>
            <strong>Sales ID:</strong> @Model.SalesId |
            <strong>Date:</strong> @Model.SalesDate.ToString("dd-MM-yyyy") |
            <strong>User:</strong> @Model.UserName
        </div>
    </div>

    <div class="p-3">

        <!-- SEARCH -->
        <div class="input-group mb-3">
            <input type="text" id="productSearch" class="form-control" placeholder="Search Product..." />
            <button class="btn btn-success" id="btnAdd" type="button">Add</button>
        </div>

        <!-- TABLE -->
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            @Html.HiddenFor(m => m.SalesId)
            @Html.HiddenFor(m => m.SalesDate)
            @Html.HiddenFor(m => m.UserName)

            <table class="table table-bordered">
                <thead class="table-primary">
                    <tr>
                        <th>SL</th>
                        <th>Product</th>
                        <th>Unit</th>
                        <th>Price</th>
                        <th>Total</th>
                    </tr>
                </thead>
                <tbody id="saleTable"></tbody>
            </table>

            <div class="text-end">
                <h4>Grand Total: <span id="grandTotal">0.00</span></h4>
            </div>

            <button type="submit" class="btn btn-primary btn-sm w-100 mt-3">
                Complete Sale
            </button>
        </form>
    </div>
</div>

<!-- UNIT MODAL -->
<div class="modal fade" id="unitModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content p-3">
            <h5>Enter Unit</h5>
            <input type="number" id="unitQty" class="form-control mb-3" min="1" value="1" />
            <button class="btn btn-primary btn-sm" id="confirmAdd" type="button">Add</button>
        </div>
    </div>
</div>

<!-- SALES LIST -->
<div class="card shadow mt-4">

    <div class="card-body text-center">

        <table class="table table-bordered table-striped">
            <thead class="table-primary ">
                <tr>
                    <th>SL</th>
                    <th>Sales ID</th>
                    <th>Date</th>
                    <th>Total</th>
                </tr>
            </thead>
            <tbody>
                @{
                    int sl = ((ViewBag.CurrentPage - 1) * 8) + 1;
                    var salesList = ViewBag.SalesList as List<Sales>;
                }

                @if (salesList != null && salesList.Any())
                {
                    foreach (var s in salesList)
                    {
                        <tr>
                            <td>@sl</td>
                            <td>@s.SalesId</td>
                            <td>@s.SalesDate.ToString("dd-MM-yyyy")</td>
                            <td>@s.GrandTotal.ToString("0.00")</td>
                        </tr>
                        sl++;
                    }
                }
                else
                {
                    <tr>
                        <td colspan="4" class="text-center text-muted">No Sales Found</td>
                    </tr>
                }
            </tbody>
        </table>

        <!-- PAGING RIGHT SIDE -->
        <div class="d-flex justify-content-end">
            <nav>
                <ul class="pagination pagination-sm mb-0">

                    @{
                        int current = ViewBag.CurrentPage;
                        int total = ViewBag.TotalPages;
                    }

                    <!-- Prev -->
                    <li class="page-item @(current == 1 ? "disabled" : "")">
                        <a class="page-link" href="?page=@(current - 1)">Prev</a>
                    </li>

                    @for (int i = 1; i <= total; i++)
                    {
                        <li class="page-item @(i == current ? "active" : "")">
                            <a class="page-link" href="?page=@i">@i</a>
                        </li>
                    }

                    <!-- Next -->
                    <li class="page-item @(current == total ? "disabled" : "")">
                        <a class="page-link" href="?page=@(current + 1)">Next</a>
                    </li>

                </ul>
            </nav>
        </div>

    </div>
</div>

@section Scripts{

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://code.jquery.com/ui/1.13.2/jquery-ui.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    @* For Sales Complete Pop-up *@
    @if (TempData["msg"] != null)
    {
        <script>
            Swal.fire({
                icon: 'success',
                title: 'Success',
                text: '@TempData["msg"]',
                confirmButtonColor: '#0d6efd'
            });
        </script>
    }

<script>
    let selectedProduct = null;
    let rowCount = 0;
    let items = [];

    $("#productSearch").autocomplete({
        source: function (request, response) {
            $.getJSON("/Sales/SearchProduct", { term: request.term }, response);
        },
        select: function (event, ui) {
            selectedProduct = ui.item;
        }
    });

    $("#btnAdd").click(function () {
        if (!selectedProduct) return;
        $("#unitModal").modal('show');
    });

    $("#confirmAdd").click(function () {

        let qty = parseInt($("#unitQty").val()) || 1;
        let total = qty * selectedProduct.price;

        rowCount++;

        items.push({
            productLiftingId: selectedProduct.id,
            productName: selectedProduct.label,
            quantity: qty,
            unitPrice: selectedProduct.price,
            totalPrice: total
        });

        $("#saleTable").append(`
            <tr>
                <td>${rowCount}</td>
                <td>${selectedProduct.label}</td>
                <td>${qty}</td>
                <td>${selectedProduct.price}</td>
                <td>${total.toFixed(2)}</td>
            </tr>
        `);

        calculateTotal();

        $("#unitModal").modal('hide');
        $("#productSearch").val('');
        selectedProduct = null;
    });

    function calculateTotal() {
        let sum = 0;
        items.forEach(x => sum += x.totalPrice);
        $("#grandTotal").text(sum.toFixed(2));

        // remove previously generated item inputs only inside the form
        $("form").find("input[name^='Items']").remove();

        items.forEach((item, index) => {
            $("form").append(`
                <input type="hidden" name="Items[${index}].ProductLiftingId" value="${item.productLiftingId}" />
                <input type="hidden" name="Items[${index}].Quantity" value="${item.quantity}" />
                <input type="hidden" name="Items[${index}].UnitPrice" value="${item.unitPrice}" />
            `);
        });
    }


</script>
}
