
@{
    ViewData["Title"] = "Delete";
}

@model Product

@{
    ViewData["Title"] = "Delete Product";
}

<h3 class="text-center text-danger">Delete Product</h3>

<h5 class="display-6 text-center text-danger">Are you sure you want to delete this?</h5>

<div class="card p-3">
    <dl class="row">
        <dt class="col-sm-3">Product Name: </dt>
        <dd class="col-sm-9">@Model.ProductName</dd>
    </dl>

    <form asp-action="Delete" method="post">
        <input type="hidden" asp-for="ProductId" />
        <button type="submit" class="btn btn-danger">Delete</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </form>
</div>

